{
  "openapi": "3.1.0",
  "info": {
    "title": "Cloud Run Containerized FastAPI Service",
    "version": "1.0.0",
    "description": "Containerized service deployment specification deployed on Google Cloud Run."
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Runtime container health verification",
        "operationId": "health_check",
        "responses": {
          "200": {
            "description": "Container is healthy and ready to accept Cloud Run proxy traffic",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "healthy"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
